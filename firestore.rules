rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - email: string (required)
    //   - name: string (required)
    //   - role: string (required, 'admin' or 'user')
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: projects
    // Document ID: {projectId}
    // Fields:
    //   - name: string (required, max 100 chars)
    //   - address: string (required, max 200 chars)
    //   - contact: string (required, max 100 chars)
    //   - houseType: string (required, max 100 chars)
    //   - startDate: timestamp (required)
    //   - ownerId: string (required, immutable, must match auth.uid)
    //   - status: string (optional, 'pending', 'in-progress', 'completed')
    //   - createdAt: timestamp (required, immutable)
    //   - updatedAt: timestamp (required)
    //
    // Collection: designers
    // Document ID: {designerId}
    // Fields:
    //   - name: string (required, max 100 chars)
    //   - ownerId: string (required, immutable, must match auth.uid)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: tasks
    // Document ID: {taskId}
    // Fields:
    //   - projectId: string (required, immutable)
    //   - ownerId: string (required, immutable)
    //   - title: string (required, max 100 chars)
    //   - description: string (optional, max 1000 chars)
    //   - startDate: timestamp (required)
    //   - startTime: string (optional, HH:mm)
    //   - endDate: timestamp (required)
    //   - endTime: string (optional, HH:mm)
    //   - status: string (required, 'pending', 'in-progress', 'completed')
    //   - createdAt: timestamp (required, immutable)
    //   - updatedAt: timestamp (required)
    //
    // Collection: calendar_shares
    // Document ID: {ownerId}_{sharedWithEmail}
    // Fields:
    //   - ownerId: string (required, immutable)
    //   - ownerEmail: string (required)
    //   - ownerName: string (required)
    //   - sharedWithEmail: string (required, immutable)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: notifications
    // Document ID: {notificationId}
    // Fields:
    //   - recipientEmail: string (required, immutable)
    //   - senderId: string (required, immutable)
    //   - senderName: string (required)
    //   - type: string (required, 'calendar_share')
    //   - message: string (required)
    //   - read: boolean (required)
    //   - createdAt: timestamp (required, immutable)
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function uidUnchanged() {
      return !('ownerId' in request.resource.data) || request.resource.data.ownerId == request.auth.uid;
    }

    function uidNotModified() {
      return !('ownerId' in request.resource.data) || request.resource.data.ownerId == resource.data.ownerId;
    }

    function hasCalendarAccess(ownerId) {
      return isAuthenticated() && 
             (ownerId != null && exists(/databases/$(database)/documents/calendar_shares/$(ownerId + "_" + request.auth.token.email)));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "schimidtz0420@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      return hasOnlyAllowedFields(['email', 'name', 'role', 'createdAt']) &&
             validStringLength('email', 3, 100) &&
             validStringLength('name', 1, 100) &&
             request.resource.data.role in ['admin', 'user'] &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidProject() {
      return hasOnlyAllowedFields(['name', 'address', 'contact', 'houseType', 'designer', 'startDate', 'ownerId', 'status', 'isShared', 'createdAt', 'updatedAt']) &&
             validStringLength('name', 1, 100) &&
             validStringLength('address', 1, 200) &&
             validStringLength('contact', 1, 100) &&
             validStringLength('houseType', 1, 100) &&
             isValidOptionalString('designer', 0, 100) &&
             request.resource.data.startDate is timestamp &&
             request.resource.data.ownerId is string &&
             (!('status' in request.resource.data) || request.resource.data.status in ['pending', 'in-progress', 'completed']) &&
             (!('isShared' in request.resource.data) || request.resource.data.isShared is bool) &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.updatedAt is timestamp;
    }

    function isValidTask() {
      return hasOnlyAllowedFields(['projectId', 'ownerId', 'title', 'description', 'startDate', 'startTime', 'endDate', 'endTime', 'status', 'subtasks', 'color', 'reminderTiming', 'reminderEmails', 'reminderPhone', 'createdAt', 'updatedAt']) &&
             request.resource.data.projectId is string &&
             request.resource.data.ownerId is string &&
             validStringLength('title', 1, 100) &&
             isValidOptionalString('description', 0, 1000) &&
             isValidOptionalString('color', 0, 50) &&
             isValidOptionalString('startTime', 0, 10) &&
             isValidOptionalString('endTime', 0, 10) &&
             (!('reminderTiming' in request.resource.data) || request.resource.data.reminderTiming in ['none', 'at_event', '1_hour', '1_day', '1_week']) &&
             (!('reminderEmails' in request.resource.data) || (request.resource.data.reminderEmails is list && request.resource.data.reminderEmails.size() <= 20)) &&
             isValidOptionalString('reminderPhone', 0, 20) &&
             request.resource.data.startDate is timestamp &&
             request.resource.data.endDate is timestamp &&
             request.resource.data.status in ['pending', 'in-progress', 'completed'] &&
             (!('subtasks' in request.resource.data) || (request.resource.data.subtasks is list && request.resource.data.subtasks.size() <= 100)) &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.updatedAt is timestamp;
    }

    function isValidCalendarShare() {
      return hasOnlyAllowedFields(['ownerId', 'ownerEmail', 'ownerName', 'sharedWithEmail', 'createdAt']) &&
             request.resource.data.ownerId is string &&
             validStringLength('ownerEmail', 3, 100) &&
             validStringLength('ownerName', 1, 100) &&
             validStringLength('sharedWithEmail', 3, 100) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidNotification() {
      return hasOnlyAllowedFields(['recipientEmail', 'senderId', 'senderName', 'type', 'message', 'read', 'createdAt']) &&
             validStringLength('recipientEmail', 3, 100) &&
             request.resource.data.senderId is string &&
             validStringLength('senderName', 1, 100) &&
             request.resource.data.type is string &&
             validStringLength('message', 1, 500) &&
             request.resource.data.read is bool &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidDesigner() {
      return hasOnlyAllowedFields(['name', 'ownerId', 'createdAt']) &&
             validStringLength('name', 1, 100) &&
             request.resource.data.ownerId is string &&
             request.resource.data.createdAt is timestamp;
    }

    // Check if the user owns the project this task belongs to
    function ownsProject(projectId) {
      return (projectId == "personal_" + request.auth.uid) ||
             (exists(/databases/$(database)/documents/projects/$(projectId)) && 
              get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid);
    }

    // Check if a project is shared
    function isProjectShared(projectId) {
      return exists(/databases/$(database)/documents/projects/$(projectId)) && 
             get(/databases/$(database)/documents/projects/$(projectId)).data.isShared == true;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser() && 
                    ((isOwner(userId) && request.resource.data.role == 'user') || isAdmin());
      allow update: if isAuthenticated() && isValidUser() && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin()) &&
                    areImmutableFieldsUnchanged(['createdAt']);
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow get: if isDocOwner() || isAdmin() || (exists(/databases/$(database)/documents/projects/$(projectId)) && resource.data.isShared == true);
      allow list: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidProject() && uidUnchanged();
      allow update: if isAuthenticated() && isValidProject() && isDocOwner() && uidNotModified() &&
                    areImmutableFieldsUnchanged(['createdAt', 'ownerId']);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /designers/{designerId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidDesigner() && uidUnchanged();
      allow update: if isAuthenticated() && isValidDesigner() && isDocOwner() && uidNotModified() &&
                    areImmutableFieldsUnchanged(['createdAt', 'ownerId']);
      allow delete: if isDocOwner() || isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if (isAuthenticated() && (resource.data.ownerId == request.auth.uid || ownsProject(resource.data.projectId) || isAdmin() || hasCalendarAccess(resource.data.ownerId))) || 
                  isProjectShared(resource.data.projectId);
      allow create: if isAuthenticated() && isValidTask() && ownsProject(request.resource.data.projectId);
      allow update: if isAuthenticated() && isValidTask() && ownsProject(resource.data.projectId) &&
                    areImmutableFieldsUnchanged(['createdAt', 'projectId', 'ownerId']);
      allow delete: if isAuthenticated() && (ownsProject(resource.data.projectId) || isAdmin());
    }

    match /calendar_shares/{shareId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.ownerId) || request.auth.token.email == resource.data.sharedWithEmail);
      allow create: if isAuthenticated() && isValidCalendarShare() && isOwner(request.resource.data.ownerId);
      allow update: if false;
      allow delete: if isAuthenticated() && isOwner(resource.data.ownerId);
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && request.auth.token.email == resource.data.recipientEmail;
      allow create: if isAuthenticated() && isValidNotification() && request.auth.uid == request.resource.data.senderId;
      allow update: if isAuthenticated() && request.auth.token.email == resource.data.recipientEmail && 
                    hasOnlyAllowedFields(['recipientEmail', 'senderId', 'senderName', 'type', 'message', 'read', 'createdAt']) &&
                    areImmutableFieldsUnchanged(['recipientEmail', 'senderId', 'senderName', 'type', 'message', 'createdAt']);
      allow delete: if isAuthenticated() && request.auth.token.email == resource.data.recipientEmail;
    }
  }
}
